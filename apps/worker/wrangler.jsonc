{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "thor-crm-index-link-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": [
    "nodejs_compat_v2"
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "ENVIRONMENT": "development",
    "SUPABASE_URL": "https://mqzchppokgaoacgkqkzh.supabase.co",
    "PUBLIC_APP_URL": "https://thor-crm-index-link-web.pages.dev"
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  },
  "queues": {
    "producers": [
      {
        "binding": "DISCOVER_QUEUE",
        "queue": "thor-crm-discover"
      },
      {
        "binding": "FETCH_QUEUE",
        "queue": "thor-crm-fetch"
      },
      {
        "binding": "MATCH_QUEUE",
        "queue": "thor-crm-match"
      }
    ],
    "consumers": [
      {
        "queue": "thor-crm-discover",
        "max_batch_size": 10,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "max_concurrency": 1,
        "retry_delay": 60
      },
      {
        "queue": "thor-crm-fetch",
        "max_batch_size": 10,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "max_concurrency": 1,
        "retry_delay": 120
      },
      {
        "queue": "thor-crm-match",
        "max_batch_size": 25,
        "max_batch_timeout": 30,
        "max_retries": 3
      }
    ]
  }
}
