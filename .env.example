SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-worker-secret-only
SUPABASE_ANON_KEY=replace-with-public-client-key
ADMIN_API_KEY=replace-with-internal-admin-key

# Web runtime mode:
# - development/staging can show demo fallback when backend is unavailable.
# - production fails closed and does not show demo listings/workflow as live product data.
VITE_THOR_RUNTIME=development
VITE_ALLOW_DEMO_FALLBACK=true
VITE_WORKER_API_URL=https://thor-crm-index-link-worker.floreaalexandru2002.workers.dev

# Optional web map tile provider. Default UI uses OpenStreetMap demo tiles.
# For production, use a paid/restricted provider URL and keep attribution accurate.
VITE_MAP_TILE_URL_TEMPLATE=https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=© OpenStreetMap contributors
